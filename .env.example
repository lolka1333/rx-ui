# Optional environment for docker compose. Copy to `.env` and edit:
#
#   cp .env.example .env
#
# Everything here is optional — with no .env at all, the container starts on
# :8080, creates an admin / admin user, and generates a JWT secret into the
# data volume. PANEL_HOST is forced to 0.0.0.0 by the image (do not set it to
# 127.0.0.1 unless the panel sits behind a reverse proxy on the same host).

# Panel HTTP port (image default: 8080).
PANEL_PORT=8080

# Log filter, comma-separated target=level (image default shown).
RUST_LOG=rx_ui=info,tower_http=info,sqlx=warn

# JWT signing secret, >= 32 chars. Leave UNSET (keep commented) to
# auto-generate one into the data volume and reuse it across restarts —
# recommended for a single host. Set it only to share sessions across
# replicas or to manage it from a secrets store.
# JWT_SECRET=replace-with-a-long-random-string-at-least-32-chars

# Initial admin password, applied on the very first run only (when the users
# table is empty). Defaults to "admin" if unset.
# ADMIN_INITIAL_PASSWORD=change-me
